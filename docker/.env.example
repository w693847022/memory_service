# MCP 服务器配置
# 传输模式: stdio, sse, streamable-http
MCP_TRANSPORT=streamable-http

# 服务器监听地址（Docker 内部）
MCP_HOST=0.0.0.0

# 服务器端口
MCP_PORT=8000

# FastAPI REST API 配置
# FastAPI 服务端口
FASTAPI_PORT=8001

# MCP Server HTTP 端点 URL（供 FastAPI 调用）
# 容器内使用服务名 mcp-memory-server 访问
MCP_SERVER_URL=http://mcp-memory-server:8000/mcp

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
MCP_LOG_LEVEL=INFO

# 存储目录（数据持久化路径）
MCP_STORAGE_DIR=/app/.project_memory_ai

# 宿主机数据目录路径
# 注意: Docker snap 版本不支持 ~ 语法，请使用绝对路径
# Linux 示例: /home/username/.project_memory_ai
# Windows: 自动使用 %USERPROFILE%\.project_memory_ai
MCP_DATA_HOST_PATH=~/.project_memory_ai

# 用户配置 - 使用宿主机用户避免文件权限问题（仅 Linux）
# Linux: 设置为当前用户的 UID/GID (运行 `id -u` 和 `id -g` 获取)
# Windows: 留空即可（Windows 不支持此配置）
# USER_ID=1000
# GROUP_ID=1000
